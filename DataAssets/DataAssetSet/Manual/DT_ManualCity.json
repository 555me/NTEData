    "Rows": {
      "1": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Leon_name",
          "SourceString": "莱昂置业",
          "LocalizedString": "莱昂置业"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Leon_desc",
          "SourceString": "买房，找莱昂！质量过硬，绝不塌房！顶层豪宅，雅静庄园！各式房产，尽在莱昂！",
          "LocalizedString": "买房，找莱昂！质量过硬，绝不塌房！顶层豪宅，雅静庄园！各式房产，尽在莱昂！"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_01.ManualCity_01",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "2": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_03_name",
          "SourceString": "Regalia",
          "LocalizedString": "Regalia"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_03_desc",
          "SourceString": "拥有百年历史的高端跑车品牌，其傲然振翅的狮鹫徽记已成为尊贵身份与顶级奢华的象征。旗下的高性能赛车更是追风者的宠儿——每一位成熟的赛车手都渴望一辆属于自己的雷加利亚！",
          "LocalizedString": "拥有百年历史的高端跑车品牌，其傲然振翅的狮鹫徽记已成为尊贵身份与顶级奢华的象征。旗下的高性能赛车更是追风者的宠儿——每一位成熟的赛车手都渴望一辆属于自己的雷加利亚！"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_02.ManualCity_02",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "3": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_name",
          "SourceString": "新越",
          "LocalizedString": "新越"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_desc",
          "SourceString": "知名汽车品牌「新越」的授权经销店，在此您可以享有一切新越品牌提供给顾客的优惠。",
          "LocalizedString": "知名汽车品牌「新越」的授权经销店，在此您可以享有一切新越品牌提供给顾客的优惠。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_03.ManualCity_03",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "4": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_02_name",
          "SourceString": "TerraX",
          "LocalizedString": "TerraX"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_035_02_desc",
          "SourceString": "由神秘探险家「铁骑士」创立的TerraX越野，以极致性能著称。其车型专为极限地形而生，曾横扫海特洛市危险地形越野挑战赛前十榜单，一战成名。",
          "LocalizedString": "由神秘探险家「铁骑士」创立的TerraX越野，以极致性能著称。其车型专为极限地形而生，曾横扫海特洛市危险地形越野挑战赛前十榜单，一战成名。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_04.ManualCity_04",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "5": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_Regalia_name",
          "SourceString": "暴走玩家",
          "LocalizedString": "暴走玩家"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Shop_Regalia_desc",
          "SourceString": "改装？维修？来暴走玩家准没错！伯骑士一号，满足您的速度的一切渴望——或是让您的爱车变得和新的一样！",
          "LocalizedString": "改装？维修？来暴走玩家准没错！伯骑士一号，满足您的速度的一切渴望——或是让您的爱车变得和新的一样！"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_05.ManualCity_05",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "6": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_PoliceStation_name",
          "SourceString": "治安所",
          "LocalizedString": "治安所"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_PoliceStation_desc",
          "SourceString": "海特洛市基层治安巡查机构，主要负责与异象和异能者无关的治安事件及民生事务。无论是坑蒙拐骗、交通肇事，还是宠物离家出走、出门忘带钥匙、外卖没给餐具……治安官们都将恪尽职守，为市民全力以赴。\r\n总之请牢记：有困难找治安所。",
          "LocalizedString": "海特洛市基层治安巡查机构，主要负责与异象和异能者无关的治安事件及民生事务。无论是坑蒙拐骗、交通肇事，还是宠物离家出走、出门忘带钥匙、外卖没给餐具……治安官们都将恪尽职守，为市民全力以赴。\r\n总之请牢记：有困难找治安所。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_06.ManualCity_06",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "7": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Prison_name",
          "SourceString": "拘留所",
          "LocalizedString": "拘留所"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_Prison_desc",
          "SourceString": "根据海特洛市治安管理条例，对于扰乱公共秩序、屡教不改者，治安所有权将其移交拘留所，予以处罚。",
          "LocalizedString": "根据海特洛市治安管理条例，对于扰乱公共秩序、屡教不改者，治安所有权将其移交拘留所，予以处罚。"
        },
