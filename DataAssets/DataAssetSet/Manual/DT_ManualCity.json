      },
      "9": {
        "Name": {
          "TableId": "/Game/Text/ST_UI_C.ST_UI_C",
          "Key": "InitAuction",
          "SourceString": "惠比寿拍卖行",
          "LocalizedString": "惠比寿拍卖行"
        },
        "Description": {
          "TableId": "/Game/Text/ST_UI_C.ST_UI_C",
          "Key": "DT_MiniMapIcon_paimai",
          "SourceString": "卡佩大酒店定期召开的普通拍卖会，无硬性入门要求，只要带够方斯。有时候拍卖会上会出现一些特殊的拍品，或许会用得上。",
          "LocalizedString": "卡佩大酒店定期召开的普通拍卖会，无硬性入门要求，只要带够方斯。有时候拍卖会上会出现一些特殊的拍品，或许会用得上。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_09.ManualCity_09",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "10": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_LiveHouse_name",
          "SourceString": "StarSign",
          "LocalizedString": "StarSign"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_LiveHouse_desc",
          "SourceString": "可以消耗城市活力进行演出，根据演出结果获取方斯。营业时间为凌晨3点到15点。\r\n经营多年的Livehouse。虽然场地不大，容纳人数有限，但因其价格亲民，颇受刚起步的乐队青睐。\r\n「将散落天际的群星缀连成为熠熠生辉的星座，或许只需要一首歌的时间。」",
          "LocalizedString": "可以消耗城市活力进行演出，根据演出结果获取方斯。营业时间为凌晨3点到15点。\r\n经营多年的Livehouse。虽然场地不大，容纳人数有限，但因其价格亲民，颇受刚起步的乐队青睐。\r\n「将散落天际的群星缀连成为熠熠生辉的星座，或许只需要一首歌的时间。」"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_10.ManualCity_10",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "11": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_WishingFountain_name",
          "SourceString": "纳库佩达之池",
          "LocalizedString": "纳库佩达之池"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_WishingFountain_desc",
          "SourceString": "纳库佩达栖身的水池。\r\n很久很久以前，这个公园以及喷泉池都还拥有着属于自己的「名字」。\r\n纳库佩达定居于此后，一切都成为了纳库佩达的附属品。\r\n\r\n纳库佩达就是一切！\r\n——纳库佩达爱好者协会宣",
          "LocalizedString": "纳库佩达栖身的水池。\r\n很久很久以前，这个公园以及喷泉池都还拥有着属于自己的「名字」。\r\n纳库佩达定居于此后，一切都成为了纳库佩达的附属品。\r\n\r\n纳库佩达就是一切！\r\n——纳库佩达爱好者协会宣"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_11.ManualCity_11",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "12": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_WishingTree_name",
          "SourceString": "福荫木",
          "LocalizedString": "福荫木"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_WishingTree_desc",
          "SourceString": "一棵巨大的树木，生长在小山丘的顶端。人们相信如此特别的大树会拥有实现愿望的力量，因此常到树下许愿，久而久之，这棵树成为了一个景点。",
          "LocalizedString": "一棵巨大的树木，生长在小山丘的顶端。人们相信如此特别的大树会拥有实现愿望的力量，因此常到树下许愿，久而久之，这棵树成为了一个景点。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_12.ManualCity_12",
          "SubPathString": ""
        },
        "IsUnlocked": true,
        "QuestId": "None"
      },
      "13": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_MaidCoffee_name",
          "SourceString": "小小麻雀",
          "LocalizedString": "小小麻雀"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_MaidCoffee_desc",
          "SourceString": "人气极高的女仆咖啡厅「小小麻雀」，不仅有元气满满的女仆提供服务，饮品和餐点也十分可口，因此广受好评。\r\n麻将是店内的最大特色。可以约上好友来休闲放松，店内的女仆也会在得到邀请时参加客人的牌局，不过坐上麻将桌的她们就会卸下可爱的笑容，变为老练、专业、毫不留情的牌手……",
          "LocalizedString": "人气极高的女仆咖啡厅「小小麻雀」，不仅有元气满满的女仆提供服务，饮品和餐点也十分可口，因此广受好评。\r\n麻将是店内的最大特色。可以约上好友来休闲放松，店内的女仆也会在得到邀请时参加客人的牌局，不过坐上麻将桌的她们就会卸下可爱的笑容，变为老练、专业、毫不留情的牌手……"
        },
