      "8": {
        "Name": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_DivinationHouse_name",
          "SourceString": "魔女之家",
          "LocalizedString": "魔女之家"
        },
        "Description": {
          "TableId": "/Game/Text/Minimap/ST_MinimapiconDec.ST_MinimapiconDec",
          "Key": "Map_DivinationHouse_desc",
          "SourceString": "若您陷入迷惘，魔女小姐可为您指出道路。",
          "LocalizedString": "若您陷入迷惘，魔女小姐可为您指出道路。"
        },
        "ImageRes": {
          "AssetPathName": "/Game/UI/UI/Manual/city/ManualCity_08.ManualCity_08",
