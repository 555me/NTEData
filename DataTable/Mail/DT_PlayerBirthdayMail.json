      "1054": {
        "MailUniqueID": "Mail_playerbirthday_1054",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1054",
          "SourceString": "多多指教",
          "LocalizedString": "多多指教"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1054",
          "SourceString": "多多指教",
          "LocalizedString": "多多指教"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1054",
          "SourceString": "上次训练的时候，看到你的武器有一点老损。记得按时维护器具，不要受伤了。今天有什么想吃的菜吗？虽然我不擅长烹饪……但我可以买一些，请教一下阿德勒先生。还有，今夜会有个好月亮，适合许愿。生日快乐，往后也请多多指教。",
          "LocalizedString": "上次训练的时候，看到你的武器有一点老损。记得按时维护器具，不要受伤了。今天有什么想吃的菜吗？虽然我不擅长烹饪……但我可以买一些，请教一下阿德勒先生。还有，今夜会有个好月亮，适合许愿。生日快乐，往后也请多多指教。"
        },
