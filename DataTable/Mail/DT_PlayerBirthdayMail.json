      "1052": {
        "MailUniqueID": "Mail_playerbirthday_1052",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1052",
          "SourceString": "来自你的好店长",
          "LocalizedString": "来自你的好店长"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1052",
          "SourceString": "来自你的好店长",
          "LocalizedString": "来自你的好店长"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1052",
          "SourceString": "大喜的日子破例给你放个假吧。如今这个世道，像我这样懂得关怀员工的老板可不多见了，你得好好珍惜啊，别被某些送快递的勾勾手指头就给糊弄去了。我让阿德勒准备了一桌好菜，还有我喜欢的你喜欢的美酒！敞开肚子大方地吃！小鬼们今天都算沾你的光！对了——许愿的时候顺便带咱们店一起许一个，你知道的……",
          "LocalizedString": "大喜的日子破例给你放个假吧。如今这个世道，像我这样懂得关怀员工的老板可不多见了，你得好好珍惜啊，别被某些送快递的勾勾手指头就给糊弄去了。我让阿德勒准备了一桌好菜，还有我喜欢的你喜欢的美酒！敞开肚子大方地吃！小鬼们今天都算沾你的光！对了——许愿的时候顺便带咱们店一起许一个，你知道的……"
        },
        "MailParams": "",
        "MailSender": {
          "TableId": "/Game/Text/ST_Player.ST_Player",
          "Key": "Role_Name_052",
          "SourceString": "浔",
          "LocalizedString": "浔"
        },
