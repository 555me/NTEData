      "1039": {
        "MailUniqueID": "Mail_playerbirthday_1039",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1039",
          "SourceString": "世界赞礼",
          "LocalizedString": "世界赞礼"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1039",
          "SourceString": "世界赞礼",
          "LocalizedString": "世界赞礼"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1039",
          "SourceString": "\"生日快乐啊~\r\n在这一天，世界一边剥夺了你对于出生的决定权，一边又给予你在当天能获得什么的欲求权——可喜可贺！想要什么、会许下什么愿望……不要吝啬地全部告诉我吧。\r\n以及，我给你准备了一个东西，绝对是你没见过的……今晚来找我，我会交给你。\r\n哎呀呀，真期待你会露出什么样的表情呢~~\"",
          "LocalizedString": "\"生日快乐啊~\r\n在这一天，世界一边剥夺了你对于出生的决定权，一边又给予你在当天能获得什么的欲求权——可喜可贺！想要什么、会许下什么愿望……不要吝啬地全部告诉我吧。\r\n以及，我给你准备了一个东西，绝对是你没见过的……今晚来找我，我会交给你。\r\n哎呀呀，真期待你会露出什么样的表情呢~~\""
        },
