      "1055": {
        "MailUniqueID": "Mail_playerbirthday_1055",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1055",
          "SourceString": "专属签收",
          "LocalizedString": "专属签收"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1055",
          "SourceString": "专属签收",
          "LocalizedString": "专属签收"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1055",
          "SourceString": "\"生日快乐，鉴定师。\r\n斯特利速递待客一向讲究，重要的日子若只托人带句话，总显得不够诚意。既然今日与你相关，我自然得亲自出面派送。礼物和祝福都已经在路上了，只差最后一道手续。\r\n——若你方便，不如来亲自签收？\"",
          "LocalizedString": "\"生日快乐，鉴定师。\r\n斯特利速递待客一向讲究，重要的日子若只托人带句话，总显得不够诚意。既然今日与你相关，我自然得亲自出面派送。礼物和祝福都已经在路上了，只差最后一道手续。\r\n——若你方便，不如来亲自签收？\""
        },
