      "1023": {
        "MailUniqueID": "Mail_playerbirthday_1023",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1023",
          "SourceString": "祝你是你",
          "LocalizedString": "祝你是你"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1023",
          "SourceString": "祝你是你",
          "LocalizedString": "祝你是你"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1023",
          "SourceString": "难怪我这最近总是睡不好，一不小心翘了几次班，总预感有大事将临……原来是因为有人今天过生日！！过生日很好，这对你的健康有益。研究表明，生日过得越多，寿命就越长！至于生日祝福……我不怎么祝对方「顺意」、「快乐」之类的，毕竟长路漫漫啊~何来坦途？就祝你是你，无所谓意义吧<(￣︶￣)>。",
          "LocalizedString": "难怪我这最近总是睡不好，一不小心翘了几次班，总预感有大事将临……原来是因为有人今天过生日！！过生日很好，这对你的健康有益。研究表明，生日过得越多，寿命就越长！至于生日祝福……我不怎么祝对方「顺意」、「快乐」之类的，毕竟长路漫漫啊~何来坦途？就祝你是你，无所谓意义吧<(￣︶￣)>。"
        },
