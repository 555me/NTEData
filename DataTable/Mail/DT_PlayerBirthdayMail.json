      "1004": {
        "MailUniqueID": "Mail_playerbirthday_1004",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1004",
          "SourceString": "礼物的真容",
          "LocalizedString": "礼物的真容"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1004",
          "SourceString": "礼物的真容",
          "LocalizedString": "礼物的真容"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1004",
          "SourceString": "\"鉴定师，生日快乐。安魂曲，没记错吧……？唔……安魂曲，记在手机上了。应该，没记错。\r\n生日，很好，可以放假。还有，好朋友会送礼物。安魂曲，是鉴定师的好朋友，也想送礼物。但是，不知道送什么好。告诉了队里，一起去挑了。店里，礼物好多好多，安魂曲，眼睛花了……最后，选好了。鉴定师，拆开看看？\"",
          "LocalizedString": "\"鉴定师，生日快乐。安魂曲，没记错吧……？唔……安魂曲，记在手机上了。应该，没记错。\r\n生日，很好，可以放假。还有，好朋友会送礼物。安魂曲，是鉴定师的好朋友，也想送礼物。但是，不知道送什么好。告诉了队里，一起去挑了。店里，礼物好多好多，安魂曲，眼睛花了……最后，选好了。鉴定师，拆开看看？\""
        },
