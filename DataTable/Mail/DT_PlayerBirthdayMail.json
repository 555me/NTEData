      "1010": {
        "MailUniqueID": "Mail_playerbirthday_1010",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1010",
          "SourceString": "来点惊喜",
          "LocalizedString": "来点惊喜"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1010",
          "SourceString": "来点惊喜",
          "LocalizedString": "来点惊喜"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1010",
          "SourceString": "\"生日快乐！！！我绝对是第一个跟你说祝福的吧，嘿嘿，这么重要的日子我可不会忘记。\r\n伊波恩的大家也都准备了礼物，蛋糕，书，奇怪的新发明，大姐头的没看到，看起来很小的一个盒子，早雾……早雾不告诉我是什么，说我知道了一定会提前告诉你，真是可惜。\r\n至于我的，我想了很久也不知道送什么，那就交给命运吧！拆到什么一定要记得告诉我，期待期待！！！\"",
          "LocalizedString": "\"生日快乐！！！我绝对是第一个跟你说祝福的吧，嘿嘿，这么重要的日子我可不会忘记。\r\n伊波恩的大家也都准备了礼物，蛋糕，书，奇怪的新发明，大姐头的没看到，看起来很小的一个盒子，早雾……早雾不告诉我是什么，说我知道了一定会提前告诉你，真是可惜。\r\n至于我的，我想了很久也不知道送什么，那就交给命运吧！拆到什么一定要记得告诉我，期待期待！！！\""
        },
