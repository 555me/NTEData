      "1008": {
        "MailUniqueID": "Mail_playerbirthday_1008",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1008",
          "SourceString": "生日快乐",
          "LocalizedString": "生日快乐"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1008",
          "SourceString": "生日快乐",
          "LocalizedString": "生日快乐"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1008",
          "SourceString": "生辰之际，谨代表异象管理局禁制机动队四队，前来致以诚挚的祝贺，生日快乐。\r\n这么郑重的话我想其他人是不会说的，就由我来传达吧……我们一直为能在管理局之外也有一位像鉴定师这样可靠的伙伴而倍感荣幸。\r\n今后也维持良好的合作关系吧。",
          "LocalizedString": "生辰之际，谨代表异象管理局禁制机动队四队，前来致以诚挚的祝贺，生日快乐。\r\n这么郑重的话我想其他人是不会说的，就由我来传达吧……我们一直为能在管理局之外也有一位像鉴定师这样可靠的伙伴而倍感荣幸。\r\n今后也维持良好的合作关系吧。"
        },
