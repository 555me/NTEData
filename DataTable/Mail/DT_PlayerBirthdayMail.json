      "1073": {
        "MailUniqueID": "Mail_playerbirthday_1073",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1073",
          "SourceString": "都要开心呀",
          "LocalizedString": "都要开心呀"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1073",
          "SourceString": "都要开心呀",
          "LocalizedString": "都要开心呀"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1073",
          "SourceString": "\"祝你生日快乐！\r\n我看到你呗果主页上写的日期是今天，希望没有出错……出错的话，就补上生日快乐，或者提前生日快乐！虽然我的祝福应该不是很重要，但还是想说给你听。\r\n我做了蛋糕，还准备了生日礼物。来了海特洛市我才知道，原来过生日的时候大家都会吃蛋糕送礼物。在准备礼物的时候，期待的情绪就一直满满的，原来就算不是自己的生日也会让人这么开心。至于礼物是什么，我想先保密，等见面之后再告诉你吧。\"",
          "LocalizedString": "\"祝你生日快乐！\r\n我看到你呗果主页上写的日期是今天，希望没有出错……出错的话，就补上生日快乐，或者提前生日快乐！虽然我的祝福应该不是很重要，但还是想说给你听。\r\n我做了蛋糕，还准备了生日礼物。来了海特洛市我才知道，原来过生日的时候大家都会吃蛋糕送礼物。在准备礼物的时候，期待的情绪就一直满满的，原来就算不是自己的生日也会让人这么开心。至于礼物是什么，我想先保密，等见面之后再告诉你吧。\""
        },
