        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1019",
          "SourceString": "可可专属惊喜派送中",
          "LocalizedString": "可可专属惊喜派送中"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1019",
          "SourceString": "可可专属惊喜派送中",
          "LocalizedString": "可可专属惊喜派送中"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1019",
          "SourceString": "\"咚咚咚！这里是踏着风而来的薄荷物流为可可送上的生日速递！请亲自签收，并支付派送费哦！我要——看到可可你今天最幸福的笑容！！！\r\n来来来，在「生日快乐！」的明信片上盖上一个大大的笑脸戳！拆开我为可可准备的专属惊喜吧！\"",
          "LocalizedString": "\"咚咚咚！这里是踏着风而来的薄荷物流为可可送上的生日速递！请亲自签收，并支付派送费哦！我要——看到可可你今天最幸福的笑容！！！\r\n来来来，在「生日快乐！」的明信片上盖上一个大大的笑脸戳！拆开我为可可准备的专属惊喜吧！\""
        },
