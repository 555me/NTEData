      "1033": {
        "MailUniqueID": "Mail_playerbirthday_1033",
        "MailType": "EHTMailType::MT_PLAYER",
        "MailSubType": "EHTMailSubType::MT_Sub_Mail_Star",
        "MailTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1033",
          "SourceString": "生日快乐",
          "LocalizedString": "生日快乐"
        },
        "MailSubTitle": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Title_1033",
          "SourceString": "生日快乐",
          "LocalizedString": "生日快乐"
        },
        "MailContent": {
          "TableId": "/Game/Text/UI/ST_PlayerBirthdayMail.ST_PlayerBirthdayMail",
          "Key": "UI_PlayerBirthday_Content_1033",
          "SourceString": "\"鉴定师，生日快乐。\r\n作为鉴定师来到伊波恩的第一个生日，虽说鄙人准备了一些礼物，多少还是有些仓促了，还望鉴定师不要介意。伊波恩的大家也都准备了礼物，今日鉴定师就好好放松一下吧，至于委托相关就由鄙人代劳吧。\r\n最后，欢迎加入伊波恩，鉴定师。\"",
          "LocalizedString": "\"鉴定师，生日快乐。\r\n作为鉴定师来到伊波恩的第一个生日，虽说鄙人准备了一些礼物，多少还是有些仓促了，还望鉴定师不要介意。伊波恩的大家也都准备了礼物，今日鉴定师就好好放松一下吧，至于委托相关就由鄙人代劳吧。\r\n最后，欢迎加入伊波恩，鉴定师。\""
        },
